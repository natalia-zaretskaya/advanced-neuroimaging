        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="&amp;#10;In this experiment, you will listen to short narratives consisting of three sentences. Please pay close attention to each narrative.&amp;#10;&amp;#10;Some narratives will describe events that naturally go together, while others may not. Your task is simply to listen attentively throughout the experiment.&amp;#10;Occasionally, you may be asked a question to ensure that you are paying attention.&amp;#10;Please remain still and focused during the entire session.&amp;#10;&amp;#10;Press Spacebar to continue.&amp;#10;&amp;#10;" valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
        <Param val="" valType="num" updates="constant" name="wrapWidth"/>
      </TextComponent>
      <CodeComponent name="code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="import random&amp;#10;&amp;#10;base = &quot;audios/&quot;&amp;#10;&amp;#10;stimuli = []&amp;#10;&amp;#10;# -----------------------&amp;#10;# COHERENT TRIALS&amp;#10;# -----------------------&amp;#10;for i in range(1, 21):&amp;#10;    name = f&quot;coh_{i}&quot;&amp;#10;&amp;#10;    stimuli.append({&amp;#10;        &quot;file&quot;: base + name + &quot;.mp3&quot;,&amp;#10;        &quot;cond&quot;: &quot;coh&quot;,&amp;#10;        &quot;question&quot;: name in [&quot;coh_1&quot;, &quot;coh_5&quot;, &quot;coh_12&quot;, &quot;coh_17&quot;]&amp;#10;    })&amp;#10;&amp;#10;# -----------------------&amp;#10;# INCOHERENT TRIALS&amp;#10;# -----------------------&amp;#10;for i in range(1, 21):&amp;#10;    name = f&quot;incoh_{i}&quot;&amp;#10;&amp;#10;    stimuli.append({&amp;#10;        &quot;file&quot;: base + name + &quot;.mp3&quot;,&amp;#10;        &quot;cond&quot;: &quot;incoh&quot;,&amp;#10;        &quot;question&quot;: name in [&quot;incoh_3&quot;, &quot;incoh_9&quot;, &quot;incoh_15&quot;, &quot;incoh_20&quot;]&amp;#10;    })&amp;#10;&amp;#10;# -----------------------&amp;#10;# RULE: no 3 same in a row&amp;#10;# -----------------------&amp;#10;def valid_sequence(seq):&amp;#10;    for i in range(len(seq) - 2):&amp;#10;        if seq[i][&quot;cond&quot;] == seq[i+1][&quot;cond&quot;] == seq[i+2][&quot;cond&quot;]:&amp;#10;            return False&amp;#10;    return True&amp;#10;&amp;#10;# -----------------------&amp;#10;# SHUFFLE UNTIL VALID&amp;#10;# -----------------------&amp;#10;while True:&amp;#10;    random.shuffle(stimuli)&amp;#10;    if valid_sequence(stimuli):&amp;#10;        break&amp;#10;&amp;#10;# FINAL trial list&amp;#10;trial_list = stimuli" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
