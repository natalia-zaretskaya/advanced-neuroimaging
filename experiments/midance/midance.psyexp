      <Param name="conditions" updates="None" val="[OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 1), ('Instruction', 'B')]), OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 1), ('Instruction', 'B')]), OrderedDict([('Condition', 1), ('Instruction', 'B')]), OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 1), ('Instruction', 'B')]), OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 1), ('Instruction', 'B')]), OrderedDict([('Condition', 2), ('Instruction', 'C')]), OrderedDict([('Condition', 1), ('Instruction', 'B')]), OrderedDict([('Condition', 1), ('Instruction', 'B')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="$f&quot;conditions/sub-{int(expInfo['participant']):03d}/ses-{int(expInfo['session']):02d}/sub-{int(expInfo['participant']):03d}_ses-{int(expInfo['session']):02d}_imagery_run-{int(expInfo['run']):02d}_conditions.csv&quot;" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="trial_imagery" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="fixation_cross"/>
    <Routine name="instruction"/>
    <Routine name="imagery"/>
    <LoopTerminator name="trial_imagery"/>
    <Routine name="end"/>
    <BidsExportRoutine name="bidsExport"/>
  </Flow>
</PsychoPy2experiment>
